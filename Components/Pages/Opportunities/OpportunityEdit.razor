@page "/opportunities/create"
@page "/opportunities/{OpportunityId:guid}/edit"
@rendermode InteractiveServer
@inject ApplicationDbContext Db
@inject NavigationManager Nav

<PageTitle>@(_isCreate ? "New opportunity" : "Edit opportunity")</PageTitle>

<h1 class="mb-4">@(_isCreate ? "New opportunity" : "Edit opportunity")</h1>

@if (!_isCreate && _entity is null)
{
    <p class="text-danger">Not found.</p>
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />
        <div class="row g-3" style="max-width:42rem">
            <div class="col-12">
                <label class="form-label">Customer</label>
                <InputSelect class="form-select" @bind-Value="_model.CustomerIdString">
                    @foreach (var c in _customers)
                    {
                        <option value="@c.CustomerId">@c.Label</option>
                    }
                </InputSelect>
            </div>
            <div class="col-12">
                <label class="form-label">Title</label>
                <InputText class="form-control" @bind-Value="_model.Title" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Status</label>
                <InputSelect class="form-select" @bind-Value="_model.Status">
                    @foreach (var s in _statuses)
                    {
                        <option value="@s">@s</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6">
                <label class="form-label">Expected value</label>
                <InputNumber class="form-control" @bind-Value="_model.ExpectedValue" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Close date</label>
                <InputDate class="form-control" @bind-Value="_model.CloseDate" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Assigned rep</label>
                <InputSelect class="form-select" @bind-Value="_model.AssignedRepIdString">
                    <option value="">—</option>
                    @foreach (var u in _users)
                    {
                        <option value="@u.UserId">@u.Name</option>
                    }
                </InputSelect>
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a class="btn btn-outline-secondary" href="@CancelHref">Cancel</a>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? OpportunityId { get; set; }

    [SupplyParameterFromQuery(Name = "customerId")]
    public Guid? CustomerIdQuery { get; set; }

    private bool _isCreate => !OpportunityId.HasValue || OpportunityId == Guid.Empty;
    private Opportunity? _entity;
    private List<CustomerOption> _customers = new();
    private List<UserOption> _users = new();
    private readonly string[] _statuses = ["Prospecting", "Qualification", "Proposal", "Negotiation", "Won", "Lost"];
    private OppForm _model = new();

    private const string CancelHref = "opportunities";

    protected override async Task OnParametersSetAsync()
    {
        _customers = await Db.Customers.AsNoTracking()
            .OrderBy(c => c.CompanyName).ThenBy(c => c.LastName)
            .Select(c => new CustomerOption(c.CustomerId, c.CompanyName != "" ? c.CompanyName : c.FirstName + " " + c.LastName))
            .ToListAsync();

        _users = await Db.Users.AsNoTracking().Where(u => u.Active)
            .OrderBy(u => u.Name)
            .Select(u => new UserOption(u.UserId, u.Name))
            .ToListAsync();

        if (_isCreate)
        {
            var pre = CustomerIdQuery ?? _customers.FirstOrDefault()?.CustomerId ?? Guid.Empty;
            _model = new OppForm
            {
                CustomerIdString = pre == Guid.Empty ? "" : pre.ToString(),
                Status = "Prospecting",
                ExpectedValue = 0,
            };
            return;
        }

        _entity = await Db.Opportunities.FirstOrDefaultAsync(o => o.OpportunityId == OpportunityId);
        if (_entity is null) return;

        _model = new OppForm
        {
            CustomerIdString = _entity.CustomerId.ToString(),
            Title = _entity.Title,
            Status = _entity.Status,
            ExpectedValue = _entity.ExpectedValue,
            CloseDate = _entity.CloseDate,
            AssignedRepIdString = _entity.AssignedRepId?.ToString() ?? "",
        };
    }

    private async Task SaveAsync()
    {
        if (!Guid.TryParse(_model.CustomerIdString, out var customerId))
            return;

        var now = DateTime.UtcNow;
        Guid? rep = string.IsNullOrEmpty(_model.AssignedRepIdString)
            ? null
            : Guid.Parse(_model.AssignedRepIdString);

        if (_isCreate)
        {
            var o = new Opportunity
            {
                OpportunityId = Guid.NewGuid(),
                CustomerId = customerId,
                Title = _model.Title.Trim(),
                Status = _model.Status,
                ExpectedValue = _model.ExpectedValue,
                CloseDate = _model.CloseDate,
                AssignedRepId = rep,
                CreatedAt = now,
                UpdatedAt = now,
            };
            Db.Opportunities.Add(o);
            await Db.SaveChangesAsync();
            Nav.NavigateTo("/opportunities");
            return;
        }

        if (_entity is null) return;
        _entity.CustomerId = customerId;
        _entity.Title = _model.Title.Trim();
        _entity.Status = _model.Status;
        _entity.ExpectedValue = _model.ExpectedValue;
        _entity.CloseDate = _model.CloseDate;
        _entity.AssignedRepId = rep;
        _entity.UpdatedAt = now;
        await Db.SaveChangesAsync();
        Nav.NavigateTo("/opportunities");
    }

    private sealed record CustomerOption(Guid CustomerId, string Label);
    private sealed record UserOption(Guid UserId, string Name);

    private sealed class OppForm
    {
        public string CustomerIdString { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(200)]
        public string Title { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required]
        public string Status { get; set; } = "Prospecting";
        public decimal ExpectedValue { get; set; }
        public DateOnly? CloseDate { get; set; }
        public string AssignedRepIdString { get; set; } = "";
    }
}
