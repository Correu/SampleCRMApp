@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center gap-3">
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted small">@context.User.Identity?.Name</span>
                    <a class="btn btn-outline-secondary btn-sm" href="/account/logout">Sign out</a>
                </Authorized>
                <NotAuthorized>
                    <a class="btn btn-primary btn-sm" href="/account/login">Sign in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
